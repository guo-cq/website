---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    I am a dedicated PhD student with a strong passion for research and academic excellence. My academic journey is driven by 
    curiosity and a commitment to advancing knowledge in my field. I bring a combination of theoretical understanding and 
    practical research experience, with a focus on rigorous methodology and innovative approaches to complex problems. 
    I am actively engaged in the academic community and seek opportunities for collaboration and knowledge exchange.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="PhD in [Your Field]"
      subtitle="2020 to Present at [University Name], [City], [Country]"
    />
    <TimeLineElement
      title="Master's Degree in [Your Field]"
      subtitle="2018 to 2020 at [University Name], [City], [Country]"
    />
    <TimeLineElement
      title="Bachelor's Degree in [Your Field]"
      subtitle="2014 to 2018 at [University Name], [City], [Country]"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Research Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Research Assistant at [Research Lab/Institute]"
      subtitle="From [Start Date] to Present at [University/Institution], [City], [Country]"
    >
      Conducting research in [specific area], focusing on [research focus]. Responsibilities include data collection and analysis, 
      literature review, experimental design, and collaboration with research team members. Contributing to ongoing projects 
      and developing independent research initiatives.
    </TimeLineElement>
    <TimeLineElement
      title="Graduate Research Project"
      subtitle="From [Start Date] to [End Date] at [University], [City], [Country]"
    >
      Led independent research project on [topic], involving [methodology]. Developed novel approaches to [problem area] 
      and presented findings at academic conferences. Collaborated with faculty advisors and peer researchers to advance 
      understanding in the field.
    </TimeLineElement>
    <TimeLineElement
      title="Undergraduate Research Assistant"
      subtitle="From [Start Date] to [End Date] at [University], [City], [Country]"
    >
      Supported faculty research initiatives through data collection, analysis, and literature review. Gained foundational 
      research experience and developed critical thinking skills essential for academic success. Contributed to research 
      publications and presentations.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Publications & Awards</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>
      <a href="#" target="_blank">Publication Title (Journal Name, Year)</a>
    </li>
    <li>
      <a href="#" target="_blank">Conference Paper Title (Conference Name, Year)</a>
    </li>
    <li>
      <a href="#" target="_blank">Academic Award or Recognition (Year)</a>
    </li>
    <li>
      <a href="#" target="_blank">Research Grant or Fellowship (Year)</a>
    </li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-5 columns-2 mx-6">
    <li>Research Methodology</li>
    <li>Data Analysis</li>
    <li>Statistical Analysis</li>
    <li>Academic Writing</li>
    <li>Literature Review</li>
    <li>Project Management</li>
    <li>Critical Thinking</li>
    <li>Problem Solving</li>
    <li>Presentation Skills</li>
    <li>Collaboration</li>
    <li>Python/R/MATLAB</li>
    <li>LaTeX</li>
    <li>Academic Research</li>
    <li>Peer Review</li>
    <li>Grant Writing</li>
  </ul>
</BaseLayout>
