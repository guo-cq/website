---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const researchProjects = (await getCollection("research")).sort((a, b) => {
  const positionA = a.data.position ?? Number.MAX_SAFE_INTEGER;
  const positionB = b.data.position ?? Number.MAX_SAFE_INTEGER;
  if (positionA !== positionB) return positionA - positionB;
  return a.data.title.localeCompare(b.data.title);
});

// 过滤掉Chemistry3D和TDM项目，只显示最新的两个
const filteredProjects = researchProjects.filter(project => 
  !project.slug.includes('chemistry3d') && 
  !project.slug.includes('tdm-tendon-driven-arms')
);
const recent_projects = filteredProjects.slice(0, 2);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Welcome to my homepage 🎓</div>
    <div class="text-5xl font-bold mb-6">I'm Guo Changqing</div>
    <div class="py-2">
      <text class="text-lg">
        I am a second-year M.Sc. student in <strong>Data Science and Information Technology</strong> at Tsinghua University (2024-2027) in the <a href="https://ssr-group.net" target="_blank" class="text-black hover:text-gray-700">Smart Sensing and Robotics Lab</a>, supervised by Prof. Wenbo Ding and Shoujie Li. I received my B.S. in <strong>Robotic Engineering</strong> from South China University of Technology (2020-2024), supervised by Prof. Hongjie Jiang.
      </text>
    </div>
    <div class="py-2">
      <text class="text-lg">
        I am committed to bridging hardware engineering and algorithmic innovation, combining hands-on engineering capabilities with cutting-edge world models to advance robotics research. I am actively seeking PhD opportunities for Spring/Fall 2027 and collaborating with fellow researchers worldwide.
      </text>
    </div>
  </div>

  <!-- Research Interests -->
  <div class="mb-6 -mt-6">
    <div class="text-3xl w-full font-bold mb-5">Research Interests</div>
    <div class="space-y-3 text-lg">
      <p>
        • 🤖🔧 <strong>Robotics:</strong> I enjoy building robots from scratch to tackle complex tasks, encompassing perception, actuation, and control systems in a full-stack approach. My previous work has focused on tactile sensing.
      </p>
      <p>
        • 🧠🖥️ <strong>Embodied AI:</strong> LLMs currently provide robots with sophisticated reasoning capabilities. I have implemented and fine-tuned VLA models, particularly for dexterous manipulation tasks.
      </p>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured Projects</div>
  </div>

  {
    recent_projects.map((project) => (
      <>
        <HorizontalCard
          title={project.data.title}
          img={project.data.heroImage}
          desc={project.data.description}
          url="/projects"
          target="_self"
          badge={project.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
