---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Academic Activities" sideBarActiveItemID="blog">
  <div class="mb-8">
    <div class="text-3xl w-full font-bold mb-6">Academic Activities</div>
  </div>

  <div class="space-y-6">
    <!-- ICRA 2026 Vienna -->
    <div class="bg-base-100 p-6 rounded-lg shadow-md">
      <h3 class="text-xl font-bold text-primary mb-2">ICRA 2026</h3>
      <p class="text-gray-600">Looking forward to participating in ICRA 2026 in Vienna. See you there!</p>
    </div>

    <!-- TRO to IROS Transfer -->
    <div class="bg-base-100 p-6 rounded-lg shadow-md">
      <h3 class="text-xl font-bold text-primary mb-2">IROS 2026</h3>
      <p class="text-gray-600">My T-RO paper SandWorm has been transferred to IROS 2026 for presentation.</p>
    </div>

    <!-- ICRA 2025 -->
    <div class="bg-base-100 p-6 rounded-lg shadow-md">
      <h3 class="text-xl font-bold text-primary mb-2">ICRA 2025</h3>
      <p class="text-gray-600">Participating in ICRA 2025 to present my research paper Chemistry3D.</p>
    </div>
  </div>

  <!-- Internship Experience -->
  <div class="mt-12 mb-8">
    <div class="text-3xl w-full font-bold mb-6">Internship Experience</div>
  </div>

  <div class="space-y-6">
    <div class="bg-base-100 p-6 rounded-lg shadow-md">
      <h3 class="text-xl font-bold text-primary mb-2">Research Intern at Meituan, Embodied AI Lab</h3>
      <p class="text-sm text-gray-500 mb-3">November 2025 to Present at Meituan, Shenzhen, China</p>
      <p class="text-gray-600">
        Working on embodied AI research projects, focusing on autonomous systems and robotic applications for
        real-world deployment in delivery and service scenarios.
      </p>
    </div>
  </div>
</BaseLayout>
